# Enforce LF line endings for all text files
* text=auto eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Lua configs
*.lua text eol=lf

# Config files
*.conf text eol=lf
*.toml text eol=lf
*.ini text eol=lf
*.jsonc text eol=lf
*.json text eol=lf
*.css text eol=lf
*.rasi text eol=lf
*.yaml text eol=lf

# Docs
*.md text eol=lf
*.txt text eol=lf

# Fish
*.fish text eol=lf

# Binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.icns binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
